# Environment Configuration
NODE_ENV=production

# Server Configuration
PORT=5000
API_URL=http://localhost:5000

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hamo-ultra

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key
REFRESH_TOKEN_EXPIRE=30d

# File Upload Configuration
UPLOAD_DIR=./uploads
TEMP_DIR=/tmp/hamo-signing
MAX_FILE_SIZE=500MB

# Apple Configuration (for IPA signing)
APPLE_TEAM_ID=your_apple_team_id
APPLE_BUNDLE_ID=com.example.app
APPLE_CERTIFICATE_PASSWORD=your_certificate_password
ZSIGN_PATH=/usr/local/bin/zsign

# Email Configuration (optional for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@hamoultra.com

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
SIGNING_PASSWORD=change-this-password

# Database Backup (optional)
BACKUP_ENABLED=false
BACKUP_INTERVAL=86400

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_APP_STORE=true
ENABLE_SIGNING=true
ENABLE_ADMIN_PANEL=true
